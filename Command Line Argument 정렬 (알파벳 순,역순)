#include <stdio.h>
#include <string.h>

/* 4.c: argv로 입력된 문자열 정렬 */
int main(int argc, char *argv[]) {
    int i, j;
    char *temp;

    if (argc < 2) return 1;

    // 버블 정렬
    for (i = 1; i < argc - 1; i++) {
        for (j = i + 1; j < argc; j++) {
            // 알파벳 순: strcmp > 0 / 역순: strcmp < 0
            if (strcmp(argv[i], argv[j]) > 0) { 
                temp = argv[i];
                argv[i] = argv[j];
                argv[j] = temp;
            }
        }
    }

    for (i = 1; i < argc; i++) printf("%s ", argv[i]);
    printf("\n");
    return 0;
}
