#include <stdio.h>

int main(void)
{
    int num = 2;      /* 현재 검사할 수 */
    int count = 0;    /* 찾은 소수 개수 */
    int i;
    int prime;

    while (count < 20) {
        prime = 1;    /* 일단 소수라고 가정 */

        /* 2부터 num-1까지 나누어떨어지는지 검사 */
        for (i = 2; i < num; i++) {
            if (num % i == 0) {
                prime = 0;   /* 나누어떨어지면 소수가 아님 */
                break;
            }
        }

        if (prime) {
            printf("%5d", num);
            count++;

            /* 5개 출력할 때마다 줄바꿈 */
            if (count % 5 == 0)
                printf("\n");
        }

        num++;
    }

    return 0;
}
