#include <stdio.h>

int main(void)
{
    char bin[100];
    int i;
    int decimal = 0;

    scanf("%s", bin);

    for (i = 0; bin[i] != '\0'; i++) {
        if (bin[i] != '0' && bin[i] != '1') {
            printf("invalid input\n");
            return 0;
        }
        decimal = decimal * 2 + (bin[i] - '0');
    }

    printf("%d\n", decimal);
    return 0;
}
