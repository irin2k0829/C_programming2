#include <stdio.h>

/* 5.c: 2부터 시작하여 N개의 소수를 구해 출력하는 프로그램 */
int main() {
    int count = 0;    // 찾은 소수의 개수
    int num = 2;      // 소수인지 검사할 숫자 (2부터 시작)
    int i, is_prime;
    int target = 20;  // 20개 또는 30개로 문제에 따라 수정

    printf("%d Prime Numbers:\n", target);

    while (count < target) {
        is_prime = 1; // 일단 소수라고 가정

        // 2부터 해당 숫자의 전까지 나누어 떨어지는지 확인
        for (i = 2; i * i <= num; i++) {
            if (num % i == 0) {
                is_prime = 0; // 나누어 떨어지면 소수가 아님
                break;
            }
        }

        // 소수로 판명되면 출력하고 카운트 증가
        if (is_prime) {
            printf("%d ", num);
            count++;
            // 10개마다 줄바꿈 (가독성용)
            if (count % 10 == 0) printf("\n");
        }
        num++; // 다음 숫자로 이동
    }
    return 0;
}
