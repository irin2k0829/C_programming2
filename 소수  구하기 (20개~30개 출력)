#include <stdio.h>

int main(void)
{
    int num = 2;          /* 검사할 수 */
    int count = 0;        /* 찾은 소수의 개수 */
    int i, isPrime;

    while (count < 30) {
        isPrime = 1;      /* 일단 소수라고 가정 */

        /* 2부터 num-1까지 나누어떨어지는지 검사 */
        for (i = 2; i < num; i++) {
            if (num % i == 0) {
                isPrime = 0;   /* 나누어떨어지면 소수가 아님 */
                break;
            }
        }

        if (isPrime) {
            printf("%5d", num);
            count++;

            /* 10개씩 출력한 뒤 줄바꿈 */
            if (count % 10 == 0)
                printf("\n");
        }

        num++;
    }

    return 0;
}
