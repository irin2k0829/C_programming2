#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>

int main(void)
{
    char op;
    double num;
    double result = 0.0;

    /* EOF가 나올 때까지 연산자와 숫자 하나를 입력받음 */
    while (scanf(" %c %lf", &op, &num) == 2) {
        switch (op) {
            case '+':
                result += num;
                break;
            case '-':
                result -= num;
                break;
            case '*':
                result *= num;
                break;
            case '/':
                if (num != 0)
                    result /= num;
                else {
                    printf("division by zero\n");
                    continue;
                }
                break;
            default:
                printf("unknown operator\n");
                continue;
        }

        printf("%g\n", result);
    }

    return 0;
}
