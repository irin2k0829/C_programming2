#include <stdio.h>
#include <string.h>

int main(void)
{
    char bin[100];
    int len, i, value;

    scanf("%s", bin);

    len = strlen(bin);

    /* 앞쪽 빈자리 보정용 */
    int rem = len % 3;
    if (rem == 1)
        printf("%d", bin[0] - '0'), i = 1;
    else if (rem == 2) {
        value = (bin[0] - '0') * 2 + (bin[1] - '0');
        printf("%d", value);
        i = 2;
    }
    else
        i = 0;

    for (; i < len; i += 3) {
        value = (bin[i] - '0') * 4 +
                (bin[i + 1] - '0') * 2 +
                (bin[i + 2] - '0');
        printf("%d", value);
    }

    printf("\n");
    return 0;
}
