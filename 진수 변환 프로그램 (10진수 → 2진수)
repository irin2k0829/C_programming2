#include <stdio.h>

int main() {
    unsigned int num;
    int i;

    // 사용자로부터 10진수 입력 받음 (scanf 사용 시 서식 지정자 주의)
    printf("Input decimal number: ");
    if (scanf("%u", &num) != 1) return 0;

    printf("Binary: ");
    
    // 32비트 정수를 가정하고 최상위 비트부터 하나씩 검사
    // i를 31부터 0까지 감소시키며 각 비트 자리를 확인
    for (i = 31; i >= 0; i--) {
        // num을 i만큼 오른쪽으로 밀고(>>) 1과 AND 연산(&) 하여 
        // 해당 자리가 0인지 1인지 판별
        int bit = (num >> i) & 1;
        printf("%d", bit);
        
        // 4비트마다 공백을 넣어 가독성 높이기 (옵션)
        if (i % 4 == 0) printf(" ");
    }
    printf("\n");

    return 0;
}
