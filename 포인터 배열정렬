#include <stdio.h>
#include <string.h>

/* 5.c: array of pointer to char 정렬 프로그램
 * 실제 문자열을 옮기지 않고 주소값(포인터)만 바꿔서 정렬함
 */

// 사진 속 빈칸: 두 포인터의 위치를 바꾸는 swap 함수
void swap(char *v[], int i, int j) {
    char *temp;
    temp = v[i];
    v[i] = v[j];
    v[j] = temp;
}

int main() {
    // 사진에 나온 초기 배열
    char *a[] = {"cherry", "apple", "banana", "date", "elderberry"};
    int n = sizeof(a) / sizeof(a[0]); // 배열의 크기
    int i, j;

    // 1. 정렬 전 출력
    printf("Before sorting:\n");
    for (i = 0; i < n; i++) {
        printf("%s ", a[i]);
    }
    printf("\n");

    // 2. 정렬 로직 (버블 정렬 방식)
    for (i = 0; i < n - 1; i++) {
        for (j = i + 1; j < n; j++) {
            // strcmp 결과가 0보다 크면 앞뒤 순서를 바꿈 (사전순)
            if (strcmp(a[i], a[j]) > 0) {
                swap(a, i, j);
            }
        }
    }

    // 3. 정렬 후 출력
    printf("After sorting:\n");
    for (i = 0; i < n; i++) {
        printf("%s ", a[i]);
    }
    printf("\n");

    return 0;
}
