#include <stdio.h>

/* * 4번 문제 예상: 입력받은 2진수 문자열을 16진수로 변환
 * 핵심: 문자 '0', '1'을 숫자 0, 1로 바꾸고 비트 합산(+= 또는 |=)
 */
int main() {
    int c;
    int bit_count = 0;
    int hex_val = 0;

    printf("Input binary (End with ^D): \n");

    // getchar()로 한 글자씩 읽으며 2진수 처리
    while ((c = getchar()) != EOF) {
        if (c == '0' || c == '1') {
            // 현재까지의 값에 2를 곱하고 새 비트를 더함 (왼쪽으로 밀기)
            hex_val = (hex_val << 1) | (c - '0');
            bit_count++;

            // 4비트가 모일 때마다 16진수 하나 출력
            if (bit_count == 4) {
                printf("Hex: %X\n", hex_val);
                hex_val = 0;   // 다음 4비트를 위해 초기화
                bit_count = 0;
            }
        } else if (c == '\n' || c == ' ' || c == '\t') {
            continue; // 공백 문자는 무시
        }
    }
    return 0;
}
