#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>
#include <string.h>

int main(void)
{
    char line[100];
    unsigned long value;
    int i, valid;
    size_t len;

    /* EOF가 나올 때까지 한 줄씩 입력받음 */
    while (fgets(line, sizeof(line), stdin) != NULL) {
        len = strlen(line);

        /* 줄 끝의 개행 문자 제거 */
        if (len > 0 && line[len - 1] == '\n')
            line[len - 1] = '\0';

        /* 빈 줄이면 건너뜀 */
        if (line[0] == '\0')
            continue;

        value = 0;
        valid = 1;

        /* 입력이 0과 1로만 이루어졌는지 검사하면서 10진수 값으로 변환 */
        for (i = 0; line[i] != '\0'; i++) {
            if (line[i] != '0' && line[i] != '1') {
                valid = 0;
                break;
            }
            value = value * 2 + (line[i] - '0');
        }

        if (valid)
            printf("%lX\n", value);   /* 16진수 대문자로 출력 */
        else
            printf("invalid input\n");
    }

    return 0;
}
