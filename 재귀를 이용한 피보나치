#include <stdio.h>

/* 재귀를 이용한 피보나치 함수 */
long long fib(int n)
{
    if (n == 0)
        return 0;
    else if (n == 1)
        return 1;
    else
        return fib(n - 1) + fib(n - 2);
}

int main(void)
{
    int i;

    /* F1부터 F20까지 출력 */
    for (i = 1; i <= 20; ++i)
        printf("F%d = %lld\n", i, fib(i));

    return 0;
}
