#include <stdio.h>
#include <string.h>

/* 문자열 배열을 출력하는 함수 */
void writelines(char *[], int);

/* 문자열 배열을 사전순으로 정렬하는 함수 */
void qsort(char *[], int, int);

/* 두 문자열 포인터의 위치를 바꾸는 함수 */
void swap(char *[], int, int);

int main(void)
{
    char *a[] = {"banana", "kiwi", "grape", "apple", "cherry"};
    int n = sizeof(a) / sizeof(char *);

    printf("\nBefore sort.\n");
    writelines(a, n);

    qsort(a, 0, n - 1);

    printf("\nAfter sort.\n");
    writelines(a, n);

    return 0;
}

/* 문자열 배열의 내용을 한 줄씩 출력 */
void writelines(char *lineptr[], int n)
{
    int i;

    for (i = 0; i < n; i++)
        printf("%s\n", lineptr[i]);
}

/* 퀵정렬을 사용하여 문자열 배열을 사전순으로 정렬 */
void qsort(char *v[], int left, int right)
{
    int i, last;

    if (left >= right)
        return;

    swap(v, left, (left + right) / 2);
    last = left;

    for (i = left + 1; i <= right; i++) {
        /* 오름차순 정렬 */
        if (strcmp(v[i], v[left]) < 0)
            swap(v, ++last, i);
    }

    swap(v, left, last);
    qsort(v, left, last - 1);
    qsort(v, last + 1, right);
}

/* 두 문자열 포인터를 교환 */
void swap(char *v[], int i, int j)
{
    char *temp;

    temp = v[i];
    v[i] = v[j];
    v[j] = temp;
}
