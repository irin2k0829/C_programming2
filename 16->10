#include <stdio.h>
#include <string.h>

int main(void)
{
    char hex[100];
    int i, value, decimal = 0;

    scanf("%s", hex);

    for (i = 0; hex[i] != '\0'; i++) {
        if (hex[i] >= '0' && hex[i] <= '9')
            value = hex[i] - '0';
        else if (hex[i] >= 'A' && hex[i] <= 'F')
            value = hex[i] - 'A' + 10;
        else if (hex[i] >= 'a' && hex[i] <= 'f')
            value = hex[i] - 'a' + 10;
        else {
            printf("invalid input\n");
            return 0;
        }

        decimal = decimal * 16 + value;
    }

    printf("%d\n", decimal);
    return 0;
}
