#include <stdio.h>
#include <string.h>

/* 4_alt.c: 포인터 배열에 저장된 문자열을 알파벳 역순으로 정렬 */
int main() {
    // 문자열 포인터 배열 선언 및 초기화
    char *a[] = {"Apple", "Cherry", "Banana", "Date", "Elderberry"};
    int n = sizeof(a) / sizeof(a[0]); // 배열의 요소 개수 계산
    int i, j;
    char *temp;

    printf("Original array:\n");
    for (i = 0; i < n; i++) printf("%s ", a[i]);
    printf("\n");

    // 정렬 알고리즘 (역순 정렬)
    for (i = 0; i < n - 1; i++) {
        for (j = i + 1; j < n; j++) {
            // strcmp 결과가 0보다 작으면 뒤의 것이 알파벳 순으로 앞섬 -> 교환하여 역순 배치
            if (strcmp(a[i], a[j]) < 0) {
                temp = a[i];
                a[i] = a[j];
                a[j] = temp;
            }
        }
    }

    printf("After sorting (Reverse Alphabetical):\n");
    for (i = 0; i < n; i++) printf("%s ", a[i]);
    printf("\n");

    return 0;
}
