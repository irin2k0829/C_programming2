#include <stdio.h>

int main(void)
{
    int c, i, nwhite, nother;
    int ndigit[10];

    /* 배열과 변수 초기화 */
    nwhite = 0;
    nother = 0;
    for (i = 0; i < 10; ++i)
        ndigit[i] = 0;

    /* 문자 입력을 하나씩 받아 분류 */
    while ((c = getchar()) != EOF) {
        if (c >= '0' && c <= '9')
            ++ndigit[c - '0'];  /* 숫자 개수 증가 */
        else if (c == ' ' || c == '\n' || c == '\t')
            ++nwhite;           /* 공백 문자 개수 증가 */
        else
            ++nother;           /* 그 외 문자 개수 증가 */
    }

    printf("digits =");
    for (i = 0; i < 10; ++i)
        printf(" %d", ndigit[i]);

    printf(", white space = %d, other = %d\n", nwhite, nother);

    return 0;
}
