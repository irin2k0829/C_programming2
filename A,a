#include <stdio.h>

int main(void)
{
    char upper = 'A';
    char lower = 'a';
    int count = 0;

    /* A~Z와 a~z를 짝지어 출력 */
    while (upper <= 'Z') {
        printf("%c%c", upper, lower);
        count++;

        /* 마지막 문자이면 줄바꿈 */
        if (upper == 'Z')
            printf("\n");
        /* 6쌍마다 줄바꿈 */
        else if (count % 6 == 0)
            printf("\n");
        /* 그 외에는 공백 출력 */
        else
            printf(" ");

        upper++;
        lower++;
    }

    return 0;
}
